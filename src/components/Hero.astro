---
import { personal } from '../data/resume';

const stats = [
  { value: '5+', label: 'Years Exp.' },
  { value: '10+', label: 'Apps Shipped' },
  { value: '6', label: 'Domains' },
  { value: '3', label: 'Companies' },
];
---

<section
  id="hero"
  aria-label="Hero"
  class="grid-bg"
  style="min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 7rem 1.5rem 5rem; overflow: hidden;"
>
  <div style="max-width: 780px; width: 100%; margin: 0 auto; text-align: center;">

    <!-- Available badge -->
    {personal.availableForWork && (
      <div class="reveal" style="display: inline-flex; margin-bottom: 2rem;">
        <div style="
          display: flex; align-items: center; gap: 0.5rem;
          padding: 0.4rem 1rem; border-radius: 9999px;
          border: 1px solid rgba(74,222,128,0.25); background: rgba(74,222,128,0.07);
          font-size: 0.74rem; font-weight: 600; color: #4ade80; letter-spacing: 0.03em;
        ">
          <span class="animate-pulse-dot" style="width: 6px; height: 6px; border-radius: 50%; background: #4ade80; display: inline-block;" aria-hidden="true"></span>
          Available for new opportunities
        </div>
      </div>
    )}

    <!-- Avatar -->
    <div class="reveal" style="display: flex; justify-content: center; margin-bottom: 2rem; transition-delay: 0.05s;">
      <div
        class="animate-float animate-glow-ring"
        style="
          width: 100px; height: 100px; border-radius: 50%;
          background: linear-gradient(135deg, #818cf8 0%, #67e8f9 100%);
          display: flex; align-items: center; justify-content: center;
          font-size: 2rem; font-weight: 800; color: white;
          letter-spacing: -0.03em;
        "
        aria-hidden="true"
      >
        {personal.initials}
      </div>
    </div>

    <!-- Name -->
    <div class="reveal" style="transition-delay: 0.1s;">
      <h1 style="font-size: clamp(2.25rem, 6vw, 3.75rem); font-weight: 800; letter-spacing: -0.04em; margin: 0 0 0.6rem; line-height: 1.05;">
        <span class="gradient-text">{personal.name}</span>
      </h1>
      <p style="font-size: clamp(1rem, 2.5vw, 1.2rem); font-weight: 500; color: #a1a1aa; margin: 0 0 1rem; letter-spacing: -0.01em;">
        {personal.title} &mdash; {personal.subtitle}
      </p>
      <p style="font-size: clamp(0.88rem, 2vw, 1rem); color: #52525b; line-height: 1.75; max-width: 520px; margin: 0 auto 2rem;">
        {personal.tagline}
      </p>
    </div>

    <!-- Tech pills -->
    <div class="reveal" style="display: flex; flex-wrap: wrap; justify-content: center; gap: 0.45rem; margin-bottom: 2.5rem; transition-delay: 0.15s;">
      {['Flutter', 'Dart', 'Kotlin', 'Bloc', 'GetX', 'Firebase', 'GraphQL', 'Socket.IO'].map((t) => (
        <span class="tech-badge">{t}</span>
      ))}
    </div>

    <!-- CTA buttons -->
    <div class="reveal" style="display: flex; flex-wrap: wrap; justify-content: center; gap: 0.75rem; margin-bottom: 3rem; transition-delay: 0.2s;">
      <a
        href="#contact"
        style="
          display: inline-flex; align-items: center; gap: 0.45rem;
          padding: 0.7rem 1.65rem; border-radius: 10px; font-size: 0.9rem; font-weight: 600;
          color: white; text-decoration: none;
          background: linear-gradient(135deg, #818cf8, #6366f1);
          box-shadow: 0 0 24px rgba(129,140,248,0.35), 0 4px 12px rgba(0,0,0,0.3);
          transition: opacity 0.2s, transform 0.2s, box-shadow 0.2s;
        "
        onmouseover="this.style.opacity='0.88';this.style.transform='translateY(-2px)';this.style.boxShadow='0 0 36px rgba(129,140,248,0.5),0 8px 20px rgba(0,0,0,0.3)'"
        onmouseout="this.style.opacity='1';this.style.transform='translateY(0)';this.style.boxShadow='0 0 24px rgba(129,140,248,0.35),0 4px 12px rgba(0,0,0,0.3)'"
      >
        Get in Touch
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a
        href="/Ajay_Resume.pdf"
        download
        class="hero-dl-btn"
        style="
          display: inline-flex; align-items: center; gap: 0.45rem;
          padding: 0.7rem 1.65rem; border-radius: 10px; font-size: 0.9rem; font-weight: 600;
          color: #d4d4d8; text-decoration: none;
          background: rgba(255,255,255,0.04);
          border: 1px solid rgba(255,255,255,0.1);
          backdrop-filter: blur(12px);
          transition: background 0.2s, border-color 0.2s, transform 0.2s, color 0.2s;
        "
        onmouseover="this.style.background='rgba(255,255,255,0.08)';this.style.borderColor='rgba(129,140,248,0.4)';this.style.transform='translateY(-2px)'"
        onmouseout="this.style.background='rgba(255,255,255,0.04)';this.style.borderColor='rgba(255,255,255,0.1)';this.style.transform='translateY(0)'"
      >
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Download Resume
      </a>
      <a
        href="#projects"
        style="
          display: inline-flex; align-items: center; gap: 0.45rem;
          padding: 0.7rem 1.65rem; border-radius: 10px; font-size: 0.9rem; font-weight: 500;
          color: #71717a; text-decoration: none;
          transition: color 0.2s, transform 0.2s;
        "
        onmouseover="this.style.color='#818cf8';this.style.transform='translateY(-2px)'"
        onmouseout="this.style.color='#71717a';this.style.transform='translateY(0)'"
      >
        View Projects →
      </a>
    </div>

    <!-- Stats strip -->
    <div class="reveal" style="transition-delay: 0.25s;">
      <div style="
        display: inline-flex; flex-wrap: wrap; justify-content: center;
        gap: 0; border-radius: 14px; overflow: hidden;
        border: 1px solid rgba(255,255,255,0.07);
        background: rgba(255,255,255,0.02);
        backdrop-filter: blur(20px);
      ">
        {stats.map((s, i) => (
          <div style={`
            padding: 1rem 1.75rem; text-align: center;
            ${i < stats.length - 1 ? 'border-right: 1px solid rgba(255,255,255,0.07);' : ''}
          `}>
            <div style="font-size: 1.5rem; font-weight: 800; letter-spacing: -0.04em;" class="gradient-text">{s.value}</div>
            <div style="font-size: 0.7rem; color: #52525b; margin-top: 0.15rem; letter-spacing: 0.04em; text-transform: uppercase; font-weight: 500;">{s.label}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Social links -->
    <div class="reveal" style="display: flex; justify-content: center; gap: 1.5rem; flex-wrap: wrap; margin-top: 2rem; transition-delay: 0.3s;">
      <a
        href={personal.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="hero-social-link"
      >
        <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        LinkedIn
      </a>
      <a
        href={`mailto:${personal.email}`}
        aria-label={`Email: ${personal.email}`}
        class="hero-social-link"
      >
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        <span class="hero-email">{personal.email}</span>
      </a>
      <span class="hero-social-link" style="cursor: default;">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        {personal.location}
      </span>
    </div>
  </div>

</section>

<style>
  .hero-social-link {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.84rem;
    color: #52525b;
    text-decoration: none;
    transition: color 0.2s;
    -webkit-font-smoothing: antialiased;
    font-variant-numeric: tabular-nums;
  }
  .hero-social-link:hover { color: #818cf8; }

  .hero-email {
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.01em;
    -webkit-font-smoothing: antialiased;
  }

  /* Light mode: Download Resume button text becomes visible */
  html.light .hero-dl-btn {
    color: #374151 !important;
    background: rgba(0,0,0,0.04) !important;
    border-color: rgba(0,0,0,0.12) !important;
  }
  html.light .hero-dl-btn:hover {
    background: rgba(0,0,0,0.07) !important;
    border-color: rgba(129,140,248,0.35) !important;
  }

  /* Light mode: social link text */
  html.light .hero-social-link { color: #6b7280; }
</style>
