---
import { personal } from '../data/resume';
---

<section
  id="hero"
  aria-label="Hero"
  style="
    min-height: 100vh; display: flex; align-items: center; justify-content: center;
    padding: 6rem 1.5rem 4rem; position: relative; overflow: hidden;
  "
>
  <!-- Grid background -->
  <div class="grid-bg" style="position: absolute; inset: 0; pointer-events: none;"></div>

  <!-- Radial glow -->
  <div style="
    position: absolute; top: 30%; left: 50%; transform: translate(-50%, -50%);
    width: 600px; height: 600px; border-radius: 50%;
    background: radial-gradient(circle, #818cf815 0%, transparent 70%);
    pointer-events: none;
  "></div>

  <div style="max-width: 800px; width: 100%; margin: 0 auto; text-align: center; position: relative;">
    <!-- Available badge -->
    {personal.availableForWork && (
      <div style="display: inline-flex; align-items: center; gap: 0.5rem; margin-bottom: 1.5rem;">
        <div style="
          display: flex; align-items: center; gap: 0.5rem;
          padding: 0.35rem 0.9rem; border-radius: 9999px;
          border: 1px solid #4ade8040; background: #4ade8010;
          font-size: 0.75rem; font-weight: 500; color: #4ade80;
        ">
          <span class="animate-pulse-dot" style="width: 6px; height: 6px; border-radius: 50%; background: #4ade80; display: inline-block;"></span>
          Available for new opportunities
        </div>
      </div>
    )}

    <!-- Avatar -->
    <div style="display: flex; justify-content: center; margin-bottom: 1.5rem;">
      <div style="
        width: 88px; height: 88px; border-radius: 50%;
        background: linear-gradient(135deg, #818cf8, #67e8f9);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.75rem; font-weight: 700; color: white;
        box-shadow: 0 0 0 3px #818cf830;
      " class="animate-float" aria-hidden="true">
        {personal.initials}
      </div>
    </div>

    <!-- Name -->
    <h1 style="font-size: clamp(2rem, 5vw, 3.25rem); font-weight: 700; letter-spacing: -0.03em; margin: 0 0 0.5rem; line-height: 1.1;">
      <span class="gradient-text">{personal.name}</span>
    </h1>

    <!-- Title -->
    <p style="font-size: clamp(1rem, 2.5vw, 1.25rem); font-weight: 500; color: #a1a1aa; margin: 0 0 1rem;">
      {personal.title} &mdash; {personal.subtitle}
    </p>

    <!-- Tagline -->
    <p style="
      font-size: clamp(0.9rem, 2vw, 1.05rem); color: #71717a; line-height: 1.7;
      max-width: 560px; margin: 0 auto 2rem;
    ">
      {personal.tagline}
    </p>

    <!-- Top tech pills -->
    <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 0.5rem; margin-bottom: 2.5rem;">
      {['Flutter', 'Dart', 'Kotlin', 'Bloc', 'GetX', 'Firebase', 'GraphQL', 'Socket.IO'].map((t) => (
        <span class="tech-badge">{t}</span>
      ))}
    </div>

    <!-- CTA buttons -->
    <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 0.75rem; margin-bottom: 2.5rem;">
      <a
        href="#contact"
        style="
          display: inline-flex; align-items: center; gap: 0.4rem;
          padding: 0.65rem 1.5rem; border-radius: 10px; font-size: 0.9rem; font-weight: 600;
          color: white; text-decoration: none;
          background: linear-gradient(135deg, #818cf8, #6366f1);
          transition: opacity 0.2s, transform 0.2s;
        "
        onmouseover="this.style.opacity='0.85';this.style.transform='translateY(-2px)'"
        onmouseout="this.style.opacity='1';this.style.transform='translateY(0)'"
      >
        Get in Touch
      </a>
      <a
        href="/Ajay_Resume.pdf"
        download
        style="
          display: inline-flex; align-items: center; gap: 0.4rem;
          padding: 0.65rem 1.5rem; border-radius: 10px; font-size: 0.9rem; font-weight: 600;
          color: #fafafa; text-decoration: none;
          border: 1px solid #262626; background: transparent;
          transition: border-color 0.2s, background 0.2s, transform 0.2s;
        "
        onmouseover="this.style.borderColor='#818cf8';this.style.background='#818cf810';this.style.transform='translateY(-2px)'"
        onmouseout="this.style.borderColor='#262626';this.style.background='transparent';this.style.transform='translateY(0)'"
      >
        ↓ Download Resume
      </a>
      <a
        href="#projects"
        style="
          display: inline-flex; align-items: center; gap: 0.4rem;
          padding: 0.65rem 1.5rem; border-radius: 10px; font-size: 0.9rem; font-weight: 600;
          color: #a1a1aa; text-decoration: none;
          border: 1px solid #1a1a1a; background: transparent;
          transition: color 0.2s, transform 0.2s;
        "
        onmouseover="this.style.color='#818cf8';this.style.transform='translateY(-2px)'"
        onmouseout="this.style.color='#a1a1aa';this.style.transform='translateY(0)'"
      >
        View Projects →
      </a>
    </div>

    <!-- Social links -->
    <div style="display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap;">
      <a
        href={personal.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        style="
          display: flex; align-items: center; gap: 0.4rem;
          font-size: 0.8rem; color: #71717a; text-decoration: none;
          transition: color 0.2s;
        "
        onmouseover="this.style.color='#818cf8'"
        onmouseout="this.style.color='#71717a'"
      >
        <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        LinkedIn
      </a>
      <a
        href={`mailto:${personal.email}`}
        aria-label="Email"
        style="
          display: flex; align-items: center; gap: 0.4rem;
          font-size: 0.8rem; color: #71717a; text-decoration: none;
          transition: color 0.2s;
        "
        onmouseover="this.style.color='#818cf8'"
        onmouseout="this.style.color='#71717a'"
      >
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
        </svg>
        {personal.email}
      </a>
      <span style="display: flex; align-items: center; gap: 0.4rem; font-size: 0.8rem; color: #71717a;">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
        </svg>
        {personal.location}
      </span>
    </div>
  </div>

  <!-- Scroll hint -->
  <div style="
    position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 0.4rem;
  ">
    <span style="font-size: 0.7rem; color: #3f3f46; letter-spacing: 0.1em; text-transform: uppercase;">Scroll</span>
    <div style="width: 1px; height: 40px; background: linear-gradient(to bottom, #818cf8, transparent);"></div>
  </div>
</section>
