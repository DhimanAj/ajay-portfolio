---
import { about, personal } from '../data/resume';
---

<section id="about" aria-labelledby="about-heading" style="padding: 5rem 1.5rem;">
  <div style="max-width: 900px; margin: 0 auto;">
    <div class="reveal">
      <p style="font-size: 0.75rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: #818cf8; margin-bottom: 0.75rem;">About</p>
      <h2 id="about-heading" style="font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 700; letter-spacing: -0.02em; margin: 0 0 2.5rem; color: #fafafa;">
        Passionate about building <span class="gradient-text">impactful mobile experiences</span>
      </h2>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start;" class="about-grid">
      <!-- Bio -->
      <div class="reveal" style="transition-delay: 0.1s;">
        {about.split('\n\n').map((para) => (
          <p style="color: #a1a1aa; line-height: 1.8; margin-bottom: 1.25rem; font-size: 0.95rem;">{para}</p>
        ))}
      </div>

      <!-- Quick stats -->
      <div class="reveal" style="transition-delay: 0.2s;">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">
          {[
            { stat: '5+', label: 'Years Experience' },
            { stat: '10+', label: 'Apps Shipped' },
            { stat: '6', label: 'Industry Domains' },
            { stat: '3', label: 'Companies' },
          ].map((item) => (
            <div style="
              padding: 1.25rem; border-radius: 12px;
              background: #111111; border: 1px solid #262626;
              text-align: center;
            " class="card-hover">
              <div style="font-size: 1.75rem; font-weight: 700; color: #818cf8;">{item.stat}</div>
              <div style="font-size: 0.75rem; color: #71717a; margin-top: 0.25rem;">{item.label}</div>
            </div>
          ))}
        </div>

        <!-- What I do -->
        <div style="padding: 1.25rem; border-radius: 12px; background: #111111; border: 1px solid #262626;">
          <p style="font-size: 0.8rem; font-weight: 600; color: #818cf8; margin: 0 0 0.75rem; text-transform: uppercase; letter-spacing: 0.08em;">What I Do</p>
          {[
            'Cross-platform Flutter development',
            'Native Android (Kotlin / Java)',
            'Real-time data integration',
            'State management architecture',
            'Play Store & App Store deployment',
            'Code reviews & mentoring',
          ].map((item) => (
            <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem;">
              <span style="width: 5px; height: 5px; border-radius: 50%; background: #818cf8; flex-shrink: 0;"></span>
              <span style="font-size: 0.85rem; color: #a1a1aa;">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @media (max-width: 768px) {
    .about-grid { grid-template-columns: 1fr !important; gap: 2rem !important; }
  }
  html.light #about h2 { color: #111111 !important; }
  html.light .about-grid div[style*="background: #111111"] {
    background: #f5f5f5 !important;
    border-color: #e0e0e0 !important;
  }
</style>
