---
import { about, personal } from '../data/resume';

const stats = [
  { stat: '5+', label: 'Years Experience' },
  { stat: '10+', label: 'Apps Shipped' },
  { stat: '6', label: 'Industry Domains' },
  { stat: '3', label: 'Companies' },
];

const whatIDo = [
  'Cross-platform Flutter development',
  'Native Android with Kotlin & Java',
  'Real-time data integration (Socket.IO, GraphQL)',
  'State management architecture (Bloc, GetX)',
  'Play Store & App Store deployment',
  'Code reviews & junior developer mentoring',
];
---

<section id="about" aria-labelledby="about-heading" style="padding: 6rem 1.5rem;">
  <div style="max-width: 940px; margin: 0 auto;">

    <div class="reveal">
      <p class="section-eyebrow"><span>01</span> About</p>
      <h2 id="about-heading" style="font-size: clamp(1.6rem, 3.5vw, 2.4rem); font-weight: 800; letter-spacing: -0.03em; margin: 0 0 2.75rem; line-height: 1.1;">
        Passionate about building <span class="gradient-text">impactful mobile experiences</span>
      </h2>
    </div>

    <div class="about-grid">
      <!-- Bio -->
      <div class="reveal" style="transition-delay: 0.08s;">
        {about.split('\n\n').map((para) => (
          <p style="color: #a1a1aa; line-height: 1.85; margin-bottom: 1.35rem; font-size: 0.95rem;">{para}</p>
        ))}
      </div>

      <!-- Stats + What I do -->
      <div class="reveal" style="transition-delay: 0.16s; display: flex; flex-direction: column; gap: 1rem;">
        <!-- Stats grid -->
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;">
          {stats.map((item) => (
            <div class="glass glass-hover" style="padding: 1.25rem; border-radius: 14px; text-align: center;">
              <div style="font-size: 1.9rem; font-weight: 800; letter-spacing: -0.04em;" class="gradient-text">{item.stat}</div>
              <div style="font-size: 0.72rem; color: #52525b; margin-top: 0.25rem; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 500;">{item.label}</div>
            </div>
          ))}
        </div>

        <!-- What I do -->
        <div class="glass" style="padding: 1.35rem; border-radius: 14px;">
          <p style="font-size: 0.7rem; font-weight: 700; color: #818cf8; margin: 0 0 1rem; text-transform: uppercase; letter-spacing: 0.1em;">What I Do</p>
          <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.55rem;">
            {whatIDo.map((item) => (
              <li style="display: flex; align-items: flex-start; gap: 0.6rem;">
                <span style="color: #818cf8; flex-shrink: 0; margin-top: 0.05rem;" aria-hidden="true">▹</span>
                <span style="font-size: 0.84rem; color: #a1a1aa; line-height: 1.5;">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }
  @media (max-width: 768px) {
    .about-grid { grid-template-columns: 1fr; gap: 2rem; }
  }
  html.light #about h2 { color: #111111; }
  html.light #about p[style*="color: #a1a1aa"] { color: #374151 !important; }
  html.light #about span[style*="color: #a1a1aa"] { color: #374151 !important; }
  html.light #about div[style*="color: #52525b"] { color: #6b7280 !important; }
</style>
