---
import { experience } from '../data/resume';

function toISO(label: string): string {
  if (label === 'Present') return '';
  const map: Record<string, string> = {
    January:'01', February:'02', March:'03', April:'04', May:'05', June:'06',
    July:'07', August:'08', September:'09', October:'10', November:'11', December:'12',
  };
  const [month, year] = label.split(' ');
  return `${year}-${map[month] ?? '01'}`;
}
---

<section id="experience" aria-labelledby="experience-heading" style="padding: 6rem 1.5rem;">
  <div style="max-width: 860px; margin: 0 auto;">

    <div class="reveal">
      <p class="section-eyebrow"><span>03</span> Experience</p>
      <h2 id="experience-heading" style="font-size: clamp(1.6rem, 3.5vw, 2.4rem); font-weight: 800; letter-spacing: -0.03em; margin: 0 0 3rem; line-height: 1.1;">
        Professional <span class="gradient-text">Journey</span>
      </h2>
    </div>

    <!-- Timeline -->
    <div style="position: relative;" role="list" aria-label="Work experience timeline">

      <!-- Connector line -->
      <div style="
        position: absolute; left: 19px; top: 8px; bottom: 8px; width: 1px;
        background: linear-gradient(to bottom, #818cf8 0%, rgba(129,140,248,0.15) 60%, transparent 100%);
      " aria-hidden="true"></div>

      {experience.map((job, i) => (
        <article
          role="listitem"
          class="reveal"
          aria-label={`${job.role} at ${job.company}`}
          itemscope
          itemtype="https://schema.org/Role"
          style={`position: relative; padding-left: 3.75rem; margin-bottom: ${i < experience.length - 1 ? '2.25rem' : '0'}; transition-delay: ${i * 0.1}s;`}
        >
          <!-- Timeline dot -->
          <div style={`
            position: absolute; left: 9px; top: 22px;
            width: 20px; height: 20px; border-radius: 50%;
            border: 2px solid ${job.current ? '#818cf8' : 'rgba(129,140,248,0.25)'};
            background: ${job.current ? '#818cf8' : '#080808'};
            ${job.current ? 'box-shadow: 0 0 0 4px rgba(129,140,248,0.12), 0 0 16px rgba(129,140,248,0.4);' : ''}
            transition: border-color 0.3s;
          `} aria-hidden="true">
            {job.current && (
              <div style="
                position: absolute; inset: 3px; border-radius: 50%;
                background: white; opacity: 0.9;
              "></div>
            )}
          </div>

          <!-- Card -->
          <div class={`glass ${job.current ? 'card-current' : 'glass-hover'}`} style={`
            padding: 1.6rem; border-radius: 16px;
            ${job.current ? 'border-left: 2px solid rgba(129,140,248,0.5) !important; box-shadow: 0 0 0 1px rgba(129,140,248,0.1), 0 8px 32px rgba(0,0,0,0.3);' : ''}
          `}>

            <!-- Header -->
            <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 0.75rem; margin-bottom: 1rem;">
              <div>
                <h3 itemprop="roleName" style="font-size: 1.05rem; font-weight: 700; color: #fafafa; margin: 0 0 0.3rem; letter-spacing: -0.01em;">{job.role}</h3>
                <p itemprop="name" style="font-size: 0.9rem; font-weight: 600; color: #818cf8; margin: 0;">{job.company}</p>
              </div>
              <div style="text-align: right; flex-shrink: 0;">
                <div style={`
                  display: inline-block; padding: 0.22rem 0.7rem; border-radius: 9999px;
                  font-size: 0.7rem; font-weight: 600; letter-spacing: 0.03em; margin-bottom: 0.3rem;
                  ${job.current
                    ? 'background: rgba(74,222,128,0.1); border: 1px solid rgba(74,222,128,0.25); color: #4ade80;'
                    : 'background: rgba(129,140,248,0.08); border: 1px solid rgba(129,140,248,0.18); color: #818cf8;'}
                `}>
                  {job.current ? '● Current' : job.type}
                </div>
                <p style="font-size: 0.76rem; color: #52525b; margin: 0; line-height: 1.5;">
                  <time datetime={toISO(job.start)} itemprop="startDate">{job.start}</time>
                  {' — '}
                  {job.current
                    ? <time>Present</time>
                    : <time datetime={toISO(job.end)} itemprop="endDate">{job.end}</time>
                  }
                </p>
                <p style="font-size: 0.72rem; color: #3f3f46; margin: 0.1rem 0 0;">{job.location}</p>
              </div>
            </div>

            <!-- Highlights -->
            <ul style="list-style: none; margin: 0 0 1.1rem; padding: 0; display: flex; flex-direction: column; gap: 0.55rem;" aria-label={`Responsibilities at ${job.company}`}>
              {job.highlights.map((h) => (
                <li style="display: flex; gap: 0.65rem; align-items: flex-start;">
                  <span style="color: #818cf8; flex-shrink: 0; margin-top: 0.28rem; font-size: 0.68rem;" aria-hidden="true">▹</span>
                  <span style="font-size: 0.85rem; color: #a1a1aa; line-height: 1.65;">{h}</span>
                </li>
              ))}
            </ul>

            <!-- Tech -->
            <div style="display: flex; flex-wrap: wrap; gap: 0.35rem;" aria-label={`Technologies at ${job.company}`}>
              {job.tech.map((t) => (
                <span class="tech-badge">{t}</span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .card-current {
    transition: box-shadow 0.25s ease;
  }
  .card-current:hover {
    box-shadow: 0 0 0 1px rgba(129,140,248,0.2), 0 12px 48px rgba(0,0,0,0.4) !important;
  }

  html.light #experience h2 { color: #111111; }
  html.light #experience h3 { color: #111111 !important; }
  html.light #experience span[style*="color: #a1a1aa"] { color: #374151 !important; }
  html.light #experience p[style*="color: #52525b"] { color: #6b7280 !important; }
  html.light #experience p[style*="color: #3f3f46"] { color: #6b7280 !important; }
</style>
