---
import { achievements } from '../data/resume';
---

<section id="achievements" aria-labelledby="achievements-heading" style="padding: 6rem 1.5rem; background: rgba(255,255,255,0.012);">
  <div style="max-width: 1040px; margin: 0 auto;">

    <div class="reveal">
      <p class="section-eyebrow"><span>06</span> Achievements</p>
      <h2 id="achievements-heading" style="font-size: clamp(1.6rem, 3.5vw, 2.4rem); font-weight: 800; letter-spacing: -0.03em; margin: 0 0 0.6rem; line-height: 1.1;">
        Key <span class="gradient-text">Highlights</span>
      </h2>
      <p style="color: #52525b; font-size: 0.9rem; margin: 0 0 2.75rem;">Measurable impact delivered across companies and domains.</p>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(310px, 1fr)); gap: 1rem;">
      {achievements.map((item, i) => (
        <div
          class="reveal glass glass-hover"
          style={`padding: 1.6rem; border-radius: 16px; transition-delay: ${i * 0.07}s;`}
        >
          <div style="display: flex; align-items: flex-start; gap: 1rem; margin-bottom: 0.85rem;">
            <div style="
              width: 44px; height: 44px; border-radius: 11px; flex-shrink: 0;
              background: linear-gradient(135deg, rgba(129,140,248,0.15), rgba(103,232,249,0.08));
              border: 1px solid rgba(129,140,248,0.18);
              display: flex; align-items: center; justify-content: center;
              font-size: 1.3rem;
            " aria-hidden="true">{item.icon}</div>
            <h3 style="font-size: 0.97rem; font-weight: 700; color: #fafafa; margin: 0; letter-spacing: -0.01em; padding-top: 0.1rem; line-height: 1.3;">{item.title}</h3>
          </div>
          <p style="font-size: 0.84rem; color: #71717a; line-height: 1.7; margin: 0;">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  html.light #achievements { background: rgba(0,0,0,0.02); }
  html.light #achievements h2 { color: #111111; }
  html.light #achievements h3 { color: #111111 !important; }
  html.light #achievements p[style*="color: #71717a"] { color: #374151 !important; }
</style>
