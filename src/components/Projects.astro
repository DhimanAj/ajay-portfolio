---
import { projects } from '../data/resume';

const featured = projects.filter((p) => p.featured);
const others = projects.filter((p) => !p.featured);
---

<section id="projects" aria-labelledby="projects-heading" style="padding: 5rem 1.5rem; background: #0d0d0d;">
  <div style="max-width: 1000px; margin: 0 auto;">
    <div class="reveal">
      <p style="font-size: 0.75rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: #818cf8; margin-bottom: 0.75rem;">Projects</p>
      <h2 id="projects-heading" style="font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 700; letter-spacing: -0.02em; margin: 0 0 0.75rem;">
        Key <span class="gradient-text">Portfolio</span>
      </h2>
      <p style="color: #71717a; margin: 0 0 2.5rem; font-size: 0.9rem;">Production-grade applications delivered across multiple industry verticals.</p>
    </div>

    <!-- Featured Projects -->
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(440px, 1fr)); gap: 1.25rem; margin-bottom: 2.5rem;" class="featured-grid">
      {featured.map((p, i) => (
        <article
          class="reveal card-hover"
          style={`
            padding: 1.5rem; border-radius: 14px;
            background: #111111; border: 1px solid #1e1e1e;
            transition-delay: ${i * 0.08}s;
          `}
          aria-label={`Project: ${p.name}`}
        >
          <!-- Domain tag -->
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem;">
            <span style="
              font-size: 0.7rem; font-weight: 600; letter-spacing: 0.08em;
              text-transform: uppercase; color: #67e8f9;
              padding: 0.2rem 0.6rem; border-radius: 9999px;
              border: 1px solid #67e8f930; background: #67e8f910;
            ">{p.domain}</span>
            <span style="font-size: 0.7rem; color: #3f3f46;">Featured</span>
          </div>

          <h3 style="font-size: 1.1rem; font-weight: 700; color: #fafafa; margin: 0 0 0.5rem;">{p.name}</h3>
          <p style="font-size: 0.85rem; color: #a1a1aa; line-height: 1.6; margin: 0 0 1rem;">{p.description}</p>

          {p.highlights.length > 0 && (
            <ul style="list-style: none; margin: 0 0 1rem; padding: 0;">
              {p.highlights.map((h) => (
                <li style="display: flex; gap: 0.5rem; margin-bottom: 0.4rem; align-items: flex-start;">
                  <span style="color: #818cf8; flex-shrink: 0; font-size: 0.7rem; margin-top: 0.3rem;">▹</span>
                  <span style="font-size: 0.8rem; color: #71717a; line-height: 1.5;">{h}</span>
                </li>
              ))}
            </ul>
          )}

          <div style="display: flex; flex-wrap: wrap; gap: 0.35rem;">
            {p.tech.map((t) => (
              <span class="tech-badge">{t}</span>
            ))}
          </div>
        </article>
      ))}
    </div>

    <!-- Other Projects -->
    <div class="reveal" style="transition-delay: 0.3s;">
      <h3 style="font-size: 0.85rem; font-weight: 600; color: #71717a; margin: 0 0 1rem; text-transform: uppercase; letter-spacing: 0.08em;">Additional Projects</h3>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 0.75rem;">
        {others.map((p, i) => (
          <div
            class="card-hover"
            style="
              padding: 1rem; border-radius: 10px;
              background: #111111; border: 1px solid #1a1a1a;
            "
            aria-label={`Project: ${p.name}`}
          >
            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.35rem;">
              <h4 style="font-size: 0.88rem; font-weight: 600; color: #d4d4d4; margin: 0;">{p.name}</h4>
              <span style="font-size: 0.65rem; color: #818cf8; flex-shrink: 0; margin-left: 0.5rem;">{p.domain}</span>
            </div>
            <p style="font-size: 0.78rem; color: #71717a; margin: 0 0 0.6rem; line-height: 1.5;">{p.description}</p>
            <div style="display: flex; flex-wrap: wrap; gap: 0.3rem;">
              {p.tech.map((t) => (
                <span style="font-size: 0.65rem; padding: 0.15rem 0.5rem; border-radius: 4px; background: #1a1a1a; border: 1px solid #262626; color: #71717a;">{t}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  @media (max-width: 640px) {
    .featured-grid { grid-template-columns: 1fr !important; }
  }
  html.light #projects { background: #f9f9f9 !important; }
  html.light #projects h2, html.light #projects h3, html.light #projects h4 { color: #111111 !important; }
  html.light div[style*="background: #111111"] { background: #ffffff !important; border-color: #e0e0e0 !important; }
</style>
