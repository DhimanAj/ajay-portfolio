---
import { projects } from '../data/resume';

const featured = projects.filter((p) => p.featured);
const others = projects.filter((p) => !p.featured);

const domainColors: Record<string, { text: string; bg: string; border: string; gradient: string }> = {
  'AI Fintech':        { text: '#818cf8', bg: 'rgba(129,140,248,0.08)', border: 'rgba(129,140,248,0.2)', gradient: '#818cf8, #6366f1' },
  'Telecom & ISP':     { text: '#38bdf8', bg: 'rgba(56,189,248,0.08)',  border: 'rgba(56,189,248,0.2)',  gradient: '#38bdf8, #0284c7' },
  'Healthcare':        { text: '#34d399', bg: 'rgba(52,211,153,0.08)',  border: 'rgba(52,211,153,0.2)',  gradient: '#34d399, #059669' },
  'On-Demand Services':{ text: '#fb923c', bg: 'rgba(251,146,60,0.08)',  border: 'rgba(251,146,60,0.2)',  gradient: '#fb923c, #ea580c' },
  'Logistics':         { text: '#facc15', bg: 'rgba(250,204,21,0.08)',  border: 'rgba(250,204,21,0.2)',  gradient: '#facc15, #ca8a04' },
  'Delivery':          { text: '#a78bfa', bg: 'rgba(167,139,250,0.08)', border: 'rgba(167,139,250,0.2)', gradient: '#a78bfa, #7c3aed' },
  'Social Media':      { text: '#f472b6', bg: 'rgba(244,114,182,0.08)', border: 'rgba(244,114,182,0.2)', gradient: '#f472b6, #db2777' },
  'EdTech':            { text: '#67e8f9', bg: 'rgba(103,232,249,0.08)', border: 'rgba(103,232,249,0.2)', gradient: '#67e8f9, #0891b2' },
  'Fintech':           { text: '#818cf8', bg: 'rgba(129,140,248,0.08)', border: 'rgba(129,140,248,0.2)', gradient: '#818cf8, #6366f1' },
};

function dc(domain: string) {
  return domainColors[domain] ?? { text: '#818cf8', bg: 'rgba(129,140,248,0.08)', border: 'rgba(129,140,248,0.2)', gradient: '#818cf8, #67e8f9' };
}
---

<section id="projects" aria-labelledby="projects-heading" style="padding: 6rem 1.5rem; background: rgba(255,255,255,0.012);">
  <div style="max-width: 1040px; margin: 0 auto;">

    <div class="reveal">
      <p class="section-eyebrow"><span>04</span> Projects</p>
      <h2 id="projects-heading" style="font-size: clamp(1.6rem, 3.5vw, 2.4rem); font-weight: 800; letter-spacing: -0.03em; margin: 0 0 0.6rem; line-height: 1.1;">
        Key <span class="gradient-text">Portfolio</span>
      </h2>
      <p style="color: #52525b; font-size: 0.9rem; margin: 0 0 2.75rem;">Production-grade applications delivered across multiple industry verticals.</p>
    </div>

    <!-- Featured Projects -->
    <div class="featured-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(450px, 1fr)); gap: 1.1rem; margin-bottom: 2.5rem;">
      {featured.map((p, i) => {
        const c = dc(p.domain);
        return (
          <article
            class="reveal glass glass-hover"
            style={`padding: 0; border-radius: 18px; overflow: hidden; transition-delay: ${i * 0.08}s;`}
            aria-label={`Project: ${p.name}`}
          >
            <!-- Top gradient accent bar -->
            <div style={`height: 2px; background: linear-gradient(90deg, ${c.gradient});`} aria-hidden="true"></div>

            <div style="padding: 1.6rem;">
              <!-- Domain + Featured -->
              <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                <span style={`
                  font-size: 0.68rem; font-weight: 700; letter-spacing: 0.08em;
                  text-transform: uppercase;
                  color: ${c.text}; padding: 0.22rem 0.65rem;
                  border-radius: 9999px; border: 1px solid ${c.border};
                  background: ${c.bg};
                `}>{p.domain}</span>
                <span style="font-size: 0.68rem; color: #3f3f46; letter-spacing: 0.05em; text-transform: uppercase; font-weight: 500;">Featured</span>
              </div>

              <h3 style="font-size: 1.15rem; font-weight: 700; color: #fafafa; margin: 0 0 0.6rem; letter-spacing: -0.02em;">{p.name}</h3>
              <p style="font-size: 0.85rem; color: #71717a; line-height: 1.7; margin: 0 0 1rem;">{p.description}</p>

              {p.highlights.length > 0 && (
                <ul style="list-style: none; margin: 0 0 1.1rem; padding: 0; display: flex; flex-direction: column; gap: 0.45rem;">
                  {p.highlights.map((h) => (
                    <li style="display: flex; gap: 0.55rem; align-items: flex-start;">
                      <span style={`color: ${c.text}; flex-shrink: 0; font-size: 0.68rem; margin-top: 0.28rem;`} aria-hidden="true">▹</span>
                      <span style="font-size: 0.8rem; color: #71717a; line-height: 1.6;">{h}</span>
                    </li>
                  ))}
                </ul>
              )}

              <div style="display: flex; flex-wrap: wrap; gap: 0.35rem; margin-bottom: 0.75rem;">
                {p.tech.map((t) => (
                  <span class="tech-badge">{t}</span>
                ))}
              </div>
              {(p.playStoreUrl || p.appStoreUrl) && (
                <div style="display: flex; flex-wrap: wrap; gap: 0.45rem;">
                  {p.playStoreUrl && (
                    <a href={p.playStoreUrl} target="_blank" rel="noopener noreferrer" class="store-btn ps-btn" aria-label={`View ${p.name} on Google Play`}>
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3.18 23.76a2.5 2.5 0 0 1-1.18-2.13V2.37a2.5 2.5 0 0 1 1.18-2.13l11.6 11.76L3.18 23.76zm13.43-7.74-2.4-2.44L5.94 22.5l10.67-6.48zm2.48-5.68a2.49 2.49 0 0 1 0 3.32l-2.11 1.28-2.67-2.71 2.67-2.71 2.11 1.28v.54zm-15.15-7.3 8.27 8.42-2.4 2.44-8.27-8.41 2.4-2.45z"/></svg>
                      Google Play
                    </a>
                  )}
                  {p.appStoreUrl && (
                    <a href={p.appStoreUrl} target="_blank" rel="noopener noreferrer" class="store-btn as-btn" aria-label={`View ${p.name} on App Store`}>
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
                      App Store
                    </a>
                  )}
                </div>
              )}
            </div>
          </article>
        );
      })}
    </div>

    <!-- Other Projects -->
    <div class="reveal" style="transition-delay: 0.28s;">
      <h3 style="font-size: 0.72rem; font-weight: 700; color: #3f3f46; margin: 0 0 1rem; text-transform: uppercase; letter-spacing: 0.1em;">Additional Projects</h3>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 0.75rem;">
        {others.map((p) => {
          const c = dc(p.domain);
          return (
            <div
              class="glass glass-hover"
              style="padding: 1.1rem 1.2rem; border-radius: 12px;"
              aria-label={`Project: ${p.name}`}
            >
              <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.4rem;">
                <h4 style="font-size: 0.88rem; font-weight: 600; color: #d4d4d8; margin: 0;">{p.name}</h4>
                <span style={`font-size: 0.62rem; color: ${c.text}; flex-shrink: 0; margin-left: 0.5rem; font-weight: 600;`}>{p.domain}</span>
              </div>
              <p style="font-size: 0.78rem; color: #52525b; margin: 0 0 0.65rem; line-height: 1.55;">{p.description}</p>
              <div style="display: flex; flex-wrap: wrap; gap: 0.3rem; margin-bottom: 0.55rem;">
                {p.tech.map((t) => (
                  <span style="font-size: 0.65rem; padding: 0.15rem 0.55rem; border-radius: 5px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); color: #52525b;">{t}</span>
                ))}
              </div>
              {(p.playStoreUrl || p.appStoreUrl) && (
                <div style="display: flex; flex-wrap: wrap; gap: 0.35rem;">
                  {p.playStoreUrl && (
                    <a href={p.playStoreUrl} target="_blank" rel="noopener noreferrer" class="store-btn ps-btn store-btn-sm" aria-label={`View ${p.name} on Google Play`}>
                      <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3.18 23.76a2.5 2.5 0 0 1-1.18-2.13V2.37a2.5 2.5 0 0 1 1.18-2.13l11.6 11.76L3.18 23.76zm13.43-7.74-2.4-2.44L5.94 22.5l10.67-6.48zm2.48-5.68a2.49 2.49 0 0 1 0 3.32l-2.11 1.28-2.67-2.71 2.67-2.71 2.11 1.28v.54zm-15.15-7.3 8.27 8.42-2.4 2.44-8.27-8.41 2.4-2.45z"/></svg>
                      Play
                    </a>
                  )}
                  {p.appStoreUrl && (
                    <a href={p.appStoreUrl} target="_blank" rel="noopener noreferrer" class="store-btn as-btn store-btn-sm" aria-label={`View ${p.name} on App Store`}>
                      <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
                      iOS
                    </a>
                  )}
                </div>
              )}
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>

<style>
  @media (max-width: 640px) {
    .featured-grid { grid-template-columns: 1fr !important; }
  }
  html.light #projects { background: rgba(0,0,0,0.02); }
  html.light #projects h2, html.light #projects h3, html.light #projects h4 { color: #111111 !important; }
  html.light .featured-grid article h3 { color: #111111 !important; }

  .store-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.32rem 0.75rem;
    border-radius: 7px;
    font-size: 0.72rem;
    font-weight: 600;
    text-decoration: none;
    border: 1px solid;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .store-btn-sm {
    font-size: 0.65rem;
    padding: 0.22rem 0.6rem;
  }

  /* Google Play — indigo */
  .ps-btn {
    color: #818cf8;
    background: rgba(129,140,248,0.08);
    border-color: rgba(129,140,248,0.22);
  }
  .ps-btn:hover {
    background: rgba(129,140,248,0.18);
    border-color: rgba(129,140,248,0.42);
    color: #a5b4fc;
  }

  /* App Store — cyan/teal */
  .as-btn {
    color: #34d399;
    background: rgba(52,211,153,0.07);
    border-color: rgba(52,211,153,0.22);
  }
  .as-btn:hover {
    background: rgba(52,211,153,0.16);
    border-color: rgba(52,211,153,0.4);
    color: #6ee7b7;
  }

  /* Light mode */
  html.light .ps-btn { color: #6366f1; background: rgba(99,102,241,0.07); border-color: rgba(99,102,241,0.2); }
  html.light .ps-btn:hover { background: rgba(99,102,241,0.14); border-color: rgba(99,102,241,0.35); color: #4338ca; }
  html.light .as-btn { color: #059669; background: rgba(5,150,105,0.07); border-color: rgba(5,150,105,0.2); }
  html.light .as-btn:hover { background: rgba(5,150,105,0.14); border-color: rgba(5,150,105,0.35); color: #047857; }
</style>
