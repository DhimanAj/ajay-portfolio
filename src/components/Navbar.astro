---
import { personal } from '../data/resume';

const navLinks = [
  { href: '#about', label: 'About' },
  { href: '#skills', label: 'Skills' },
  { href: '#experience', label: 'Experience' },
  { href: '#projects', label: 'Projects' },
  { href: '#education', label: 'Education' },
  { href: '#contact', label: 'Contact' },
];
---

<nav id="navbar" aria-label="Main navigation">
  <div class="nav-inner">
    <!-- Logo -->
    <a href="#hero" aria-label="Home" class="nav-logo">
      <div class="logo-mark" aria-hidden="true">{personal.initials}</div>
      <span class="logo-name">{personal.name.split(' ')[0]}</span>
    </a>

    <!-- Desktop nav -->
    <ul class="desktop-nav" role="list">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="nav-link">{link.label}</a>
        </li>
      ))}
    </ul>

    <!-- Right actions -->
    <div class="nav-actions">
      <button id="theme-toggle" aria-label="Toggle theme" class="icon-btn">
        <span class="icon-dark">🌙</span>
        <span class="icon-light" style="display:none;">☀️</span>
      </button>
      <a href="/Ajay_Resume.pdf" download class="resume-btn">
        <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Resume
      </a>
      <button id="mobile-menu-btn" aria-label="Open menu" aria-expanded="false" class="icon-btn mobile-only">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="mobile-menu" style="display:none;">
    <ul role="list">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="mobile-nav-link">{link.label}</a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  #navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 50;
    background: rgba(8,8,8,0.6);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }
  #navbar.scrolled {
    background: rgba(8,8,8,0.85);
    box-shadow: 0 1px 0 rgba(129,140,248,0.12), 0 4px 24px rgba(0,0,0,0.4);
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 62px;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
  }
  .logo-mark {
    width: 36px; height: 36px;
    border-radius: 9px;
    background: linear-gradient(135deg, #818cf8, #67e8f9);
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 0.82rem; color: white;
    box-shadow: 0 0 16px rgba(129,140,248,0.35);
    flex-shrink: 0;
  }
  .logo-name {
    font-weight: 600;
    font-size: 0.9rem;
    color: #fafafa;
    letter-spacing: -0.01em;
  }

  .desktop-nav {
    display: flex;
    list-style: none;
    margin: 0; padding: 0;
    gap: 0.15rem;
  }
  .nav-link {
    display: block;
    padding: 0.4rem 0.8rem;
    border-radius: 7px;
    font-size: 0.84rem;
    font-weight: 500;
    color: #71717a;
    text-decoration: none;
    transition: color 0.2s, background 0.2s;
    position: relative;
  }
  .nav-link:hover { color: #e4e4e7 !important; background: rgba(255,255,255,0.05) !important; }
  .nav-link.active {
    color: #818cf8 !important;
    background: rgba(129,140,248,0.08) !important;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .icon-btn {
    width: 36px; height: 36px;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.03);
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    color: #a1a1aa;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
    font-size: 0.9rem;
  }
  .icon-btn:hover {
    background: rgba(255,255,255,0.07);
    border-color: rgba(255,255,255,0.15);
    color: #fafafa;
  }

  .resume-btn {
    display: flex; align-items: center; gap: 0.4rem;
    padding: 0.42rem 1rem;
    border-radius: 8px;
    font-size: 0.8rem; font-weight: 600;
    color: white;
    text-decoration: none;
    background: linear-gradient(135deg, #818cf8, #6366f1);
    box-shadow: 0 0 16px rgba(129,140,248,0.3);
    transition: opacity 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .resume-btn:hover {
    opacity: 0.9;
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(129,140,248,0.45);
  }

  .mobile-only { display: none !important; }

  .mobile-menu {
    border-top: 1px solid rgba(255,255,255,0.06);
    background: rgba(8,8,8,0.95);
  }
  .mobile-menu ul {
    list-style: none; margin: 0;
    padding: 0.75rem 1.5rem 1rem;
    display: flex; flex-direction: column; gap: 0.2rem;
  }
  .mobile-nav-link {
    display: block;
    padding: 0.65rem 0.85rem;
    border-radius: 8px;
    font-size: 0.9rem; font-weight: 500;
    color: #71717a;
    text-decoration: none;
    transition: color 0.2s, background 0.2s;
  }
  .mobile-nav-link:hover { color: #818cf8 !important; background: rgba(129,140,248,0.08) !important; }

  @media (max-width: 768px) {
    .desktop-nav { display: none !important; }
    .mobile-only { display: flex !important; }
    .resume-btn span { display: none; }
  }

  /* Light mode */
  html.light #navbar {
    background: rgba(245,245,245,0.75) !important;
    border-bottom-color: rgba(0,0,0,0.08) !important;
  }
  html.light #navbar.scrolled {
    background: rgba(245,245,245,0.92) !important;
    box-shadow: 0 1px 0 rgba(0,0,0,0.08), 0 4px 24px rgba(0,0,0,0.06) !important;
  }
  html.light .nav-link { color: #6b7280 !important; }
  html.light .nav-link:hover { color: #111 !important; background: rgba(0,0,0,0.04) !important; }
  html.light .logo-name { color: #111111; }
  html.light .icon-btn { border-color: rgba(0,0,0,0.1); background: rgba(0,0,0,0.03); color: #6b7280; }
  html.light .mobile-menu { background: rgba(245,245,245,0.98); border-top-color: rgba(0,0,0,0.08); }
  html.light .mobile-nav-link { color: #6b7280 !important; }
</style>

<script>
  const navbar = document.getElementById('navbar');
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const themeBtn = document.getElementById('theme-toggle');
  const iconDark = document.querySelector('.icon-dark') as HTMLElement | null;
  const iconLight = document.querySelector('.icon-light') as HTMLElement | null;

  // Scrolled state
  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('scrolled', window.scrollY > 20);
  });

  // Mobile menu
  mobileBtn?.addEventListener('click', () => {
    const open = mobileMenu?.style.display === 'block';
    if (mobileMenu) mobileMenu.style.display = open ? 'none' : 'block';
    mobileBtn.setAttribute('aria-expanded', String(!open));
  });
  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      if (mobileMenu) mobileMenu.style.display = 'none';
    });
  });

  // Theme toggle
  function updateIcons() {
    const isLight = document.documentElement.classList.contains('light');
    if (iconDark) iconDark.style.display = isLight ? 'none' : 'block';
    if (iconLight) iconLight.style.display = isLight ? 'block' : 'none';
  }
  updateIcons();
  themeBtn?.addEventListener('click', () => {
    const isLight = document.documentElement.classList.contains('light');
    document.documentElement.classList.toggle('light', !isLight);
    document.documentElement.classList.toggle('dark', isLight);
    localStorage.setItem('theme', isLight ? 'dark' : 'light');
    updateIcons();
  });

  // Active section highlight
  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('.nav-link');
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navLinks.forEach((link) => {
            link.classList.toggle('active', link.getAttribute('href') === '#' + entry.target.id);
          });
        }
      });
    },
    { rootMargin: '-45% 0px -45% 0px' }
  );
  sections.forEach((s) => io.observe(s));
</script>
