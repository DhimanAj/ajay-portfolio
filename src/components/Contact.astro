---
import { personal } from '../data/resume';

const contacts = [
  {
    label: 'Email',
    value: personal.email,
    href: `mailto:${personal.email}`,
    ariaLabel: `Send email to ${personal.email}`,
    icon: `<svg width="18" height="18" fill="none" stroke="#818cf8" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
    itemprop: 'email',
    external: false,
  },
  {
    label: 'Phone',
    value: personal.phone,
    href: `tel:${personal.phone}`,
    ariaLabel: `Call ${personal.phone}`,
    icon: `<svg width="18" height="18" fill="none" stroke="#818cf8" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.39 2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.77a16 16 0 0 0 6.29 6.29l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`,
    itemprop: 'telephone',
    external: false,
  },
  {
    label: 'LinkedIn',
    value: 'ajay-dhiman-90075919a',
    href: personal.linkedin,
    ariaLabel: 'View LinkedIn profile (opens in new tab)',
    icon: `<svg width="18" height="18" fill="#818cf8" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
    itemprop: 'sameAs',
    external: true,
  },
];
---

<section id="contact" aria-labelledby="contact-heading" style="padding: 6rem 1.5rem;">
  <div style="max-width: 720px; margin: 0 auto;">

    <div class="reveal" style="text-align: center; margin-bottom: 3rem;">
      <p class="section-eyebrow" style="justify-content: center;"><span>07</span> Contact</p>
      <h2 id="contact-heading" style="font-size: clamp(1.6rem, 3.5vw, 2.4rem); font-weight: 800; letter-spacing: -0.03em; margin: 0 0 0.85rem; line-height: 1.1;">
        Let's <span class="gradient-text">Work Together</span>
      </h2>
      <p style="color: #52525b; font-size: 0.95rem; max-width: 460px; margin: 0 auto; line-height: 1.75;">
        I'm currently open to new opportunities. Whether you have a project in mind, want to discuss a role, or just want to say hi — my inbox is always open.
      </p>
    </div>

    <address
      itemscope
      itemtype="https://schema.org/Person"
      style="font-style: normal;"
      aria-label="Contact information for Ajay Dhiman"
    >
      <meta itemprop="name" content={personal.name} />
      <meta itemprop="jobTitle" content={personal.title} />

      <div style="display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 2rem;">
        {contacts.map((c, i) => (
          <a
            href={c.href}
            target={c.external ? '_blank' : undefined}
            rel={c.external ? 'noopener noreferrer' : undefined}
            class="reveal glass glass-hover"
            itemprop={c.itemprop}
            style={`
              display: flex; align-items: center; gap: 1.1rem;
              padding: 1.25rem 1.5rem; border-radius: 14px;
              text-decoration: none; color: inherit;
              transition-delay: ${i * 0.07}s;
            `}
            aria-label={c.ariaLabel}
          >
            <div style="
              width: 44px; height: 44px; border-radius: 11px; flex-shrink: 0;
              background: rgba(129,140,248,0.1);
              border: 1px solid rgba(129,140,248,0.2);
              display: flex; align-items: center; justify-content: center;
            " aria-hidden="true" set:html={c.icon}></div>
            <div style="min-width: 0;">
              <p style="font-size: 0.7rem; color: #3f3f46; margin: 0 0 0.2rem; text-transform: uppercase; letter-spacing: 0.07em; font-weight: 600;">{c.label}</p>
              <p style="font-size: 0.88rem; font-weight: 500; color: #d4d4d8; margin: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">{c.value}</p>
            </div>
            <div style="margin-left: auto; color: #3f3f46; flex-shrink: 0;" aria-hidden="true">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </a>
        ))}

        <!-- Location (non-link) -->
        <div
          class="reveal glass"
          style="
            display: flex; align-items: center; gap: 1.1rem;
            padding: 1.25rem 1.5rem; border-radius: 14px;
            transition-delay: 0.21s;
          "
        >
          <div style="
            width: 44px; height: 44px; border-radius: 11px; flex-shrink: 0;
            background: rgba(129,140,248,0.1);
            border: 1px solid rgba(129,140,248,0.2);
            display: flex; align-items: center; justify-content: center;
          " aria-hidden="true">
            <svg width="18" height="18" fill="none" stroke="#818cf8" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <p style="font-size: 0.7rem; color: #3f3f46; margin: 0 0 0.2rem; text-transform: uppercase; letter-spacing: 0.07em; font-weight: 600;">Location</p>
            <p
              itemprop="address"
              itemscope
              itemtype="https://schema.org/PostalAddress"
              style="font-size: 0.88rem; font-weight: 500; color: #d4d4d8; margin: 0;"
            >
              <span itemprop="addressLocality">Mohali</span>, <span itemprop="addressCountry">India</span>
            </p>
          </div>
        </div>
      </div>
    </address>

    <!-- CTA -->
    <div class="reveal" style="text-align: center; transition-delay: 0.28s;">
      <a
        href={`mailto:${personal.email}`}
        style="
          display: inline-flex; align-items: center; gap: 0.6rem;
          padding: 0.8rem 2.25rem; border-radius: 12px; font-size: 0.95rem; font-weight: 600;
          color: white; text-decoration: none;
          background: linear-gradient(135deg, #818cf8, #6366f1);
          box-shadow: 0 0 28px rgba(129,140,248,0.35), 0 6px 16px rgba(0,0,0,0.3);
          transition: opacity 0.2s, transform 0.2s, box-shadow 0.2s;
        "
        onmouseover="this.style.opacity='0.88';this.style.transform='translateY(-2px)';this.style.boxShadow='0 0 44px rgba(129,140,248,0.5),0 10px 24px rgba(0,0,0,0.3)'"
        onmouseout="this.style.opacity='1';this.style.transform='translateY(0)';this.style.boxShadow='0 0 28px rgba(129,140,248,0.35),0 6px 16px rgba(0,0,0,0.3)'"
      >
        Say Hello 👋
      </a>
    </div>
  </div>
</section>

<style>
  html.light #contact h2 { color: #111111; }
  html.light #contact p[style*="color: #d4d4d8"] { color: #111111 !important; }
  .section-eyebrow[style*="justify-content: center"]::after { display: none; }
</style>
