---
import { personal } from '../data/resume';

const year = new Date().getFullYear();

const navLinks = [
  { href: '#about', label: 'About' },
  { href: '#skills', label: 'Skills' },
  { href: '#experience', label: 'Experience' },
  { href: '#projects', label: 'Projects' },
  { href: '#education', label: 'Education' },
  { href: '#contact', label: 'Contact' },
];
---

<footer role="contentinfo" class="site-footer">
  <!-- Top gradient line -->
  <div style="height: 1px; background: linear-gradient(90deg, transparent, rgba(129,140,248,0.3), rgba(103,232,249,0.2), transparent);" aria-hidden="true"></div>

  <div style="max-width: 1040px; margin: 0 auto; padding: 2.75rem 1.5rem 1.75rem;">
    <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 2rem; margin-bottom: 2.25rem;">

      <!-- Brand -->
      <div>
        <div style="display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.6rem;">
          <div style="
            width: 32px; height: 32px; border-radius: 8px;
            background: linear-gradient(135deg, #818cf8, #67e8f9);
            display: flex; align-items: center; justify-content: center;
            font-weight: 700; font-size: 0.78rem; color: white;
            box-shadow: 0 0 12px rgba(129,140,248,0.3);
          " aria-hidden="true">{personal.initials}</div>
          <span style="font-weight: 600; color: #d4d4d8; font-size: 0.9rem; letter-spacing: -0.01em;">{personal.name}</span>
        </div>
        <p style="font-size: 0.78rem; color: #3f3f46; margin: 0; max-width: 220px; line-height: 1.65;">
          Flutter & Android Developer building impactful mobile experiences.
        </p>
      </div>

      <!-- Nav -->
      <nav aria-label="Footer navigation">
        <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: 0.5rem 1.25rem;">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                style="font-size: 0.82rem; color: #3f3f46; text-decoration: none; transition: color 0.2s; font-weight: 500;"
                onmouseover="this.style.color='#818cf8'"
                onmouseout="this.style.color='#3f3f46'"
              >{link.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Social icons -->
      <div style="display: flex; gap: 0.65rem;">
        <a
          href={personal.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="social-icon"
        >
          <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a
          href={`mailto:${personal.email}`}
          aria-label="Email"
          class="social-icon"
        >
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </a>
        <a
          href={personal.github}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="social-icon"
        >
          <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div style="border-top: 1px solid rgba(255,255,255,0.04); padding-top: 1.25rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem;">
      <p class="footer-meta" style="font-size: 0.74rem; margin: 0;">
        &copy; {year} {personal.name}. All rights reserved.
      </p>
      <p class="footer-meta" style="font-size: 0.74rem; margin: 0;">
        Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer" style="color: #818cf8; text-decoration: none;" onmouseover="this.style.textDecoration='underline'" onmouseout="this.style.textDecoration='none'">Astro</a> &amp; Tailwind CSS
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: rgba(4,4,4,0.95);
  }
  .social-icon {
    width: 36px; height: 36px;
    border-radius: 9px;
    border: 1px solid rgba(255,255,255,0.06);
    background: rgba(255,255,255,0.03);
    display: flex; align-items: center; justify-content: center;
    color: #3f3f46;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
    text-decoration: none;
  }
  .social-icon:hover {
    border-color: rgba(129,140,248,0.3);
    color: #818cf8;
    background: rgba(129,140,248,0.07);
  }

  .footer-meta { color: #52525b; }

  html.light .site-footer { background: rgba(235,235,235,0.95); }
  html.light .site-footer span[style*="color: #d4d4d8"] { color: #111111 !important; }
  html.light .social-icon { border-color: rgba(0,0,0,0.1); background: rgba(0,0,0,0.03); }
  html.light .footer-meta { color: #6b7280; }
</style>
