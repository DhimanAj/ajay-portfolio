---
import { skills } from '../data/resume';

const categoryIcons: Record<string, string> = {
  'Mobile Development': '📱',
  'Architecture & Patterns': '🏗️',
  'State Management': '⚙️',
  'Backend & APIs': '🔌',
  'Cloud & Services': '☁️',
  'UI/UX': '🎨',
  'Testing & Quality': '✅',
  'Tools & DevOps': '🛠️',
  'Methodologies': '🔄',
};
---

<section id="skills" aria-labelledby="skills-heading" style="padding: 6rem 1.5rem; background: rgba(255,255,255,0.012);">
  <div style="max-width: 1040px; margin: 0 auto;">

    <div class="reveal">
      <p class="section-eyebrow"><span>02</span> Skills</p>
      <h2 id="skills-heading" style="font-size: clamp(1.6rem, 3.5vw, 2.4rem); font-weight: 800; letter-spacing: -0.03em; margin: 0 0 0.6rem; line-height: 1.1;">
        Technical <span class="gradient-text">Expertise</span>
      </h2>
      <p style="color: #52525b; font-size: 0.9rem; margin: 0 0 2.75rem;">A broad skill set built across 5+ years of production mobile development.</p>
    </div>

    <div
      style="display: grid; grid-template-columns: repeat(auto-fill, minmax(290px, 1fr)); gap: 1rem;"
      itemscope
      itemtype="https://schema.org/ItemList"
      aria-label="Technical skills grouped by category"
    >
      {skills.map((group, i) => (
        <div
          class="reveal glass glass-hover"
          role="group"
          aria-labelledby={`skill-cat-${i}`}
          style={`padding: 1.35rem; border-radius: 16px; transition-delay: ${i * 0.05}s;`}
        >
          <!-- Category header -->
          <div style="display: flex; align-items: center; gap: 0.6rem; margin-bottom: 1rem;">
            <span style="font-size: 1.1rem; line-height: 1;" aria-hidden="true">
              {categoryIcons[group.category] ?? '⚡'}
            </span>
            <h3
              id={`skill-cat-${i}`}
              style="font-size: 0.76rem; font-weight: 700; color: #818cf8; margin: 0; text-transform: uppercase; letter-spacing: 0.09em;"
            >
              {group.category}
            </h3>
          </div>

          <!-- Skills -->
          <ul style="display: flex; flex-wrap: wrap; gap: 0.4rem; list-style: none; margin: 0; padding: 0;">
            {group.items.map((skill) => (
              <li itemprop="itemListElement">
                <span
                  itemprop="name"
                  class="skill-pill"
                >
                  {skill}
                </span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .skill-pill {
    display: inline-block;
    padding: 0.28rem 0.7rem;
    border-radius: 7px;
    font-size: 0.78rem;
    font-weight: 500;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    color: #c4c4c8;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
    cursor: default;
  }
  .skill-pill:hover {
    background: rgba(129,140,248,0.1) !important;
    border-color: rgba(129,140,248,0.3) !important;
    color: #818cf8 !important;
  }

  html.light .skill-pill {
    background: rgba(0,0,0,0.04);
    border-color: rgba(0,0,0,0.1);
    color: #374151;
  }
  html.light #skills { background: rgba(0,0,0,0.02); }
  html.light #skills h2 { color: #111111; }
</style>
