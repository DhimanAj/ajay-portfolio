---
import { education } from '../data/resume';
---

<section id="education" aria-labelledby="education-heading" style="padding: 6rem 1.5rem;">
  <div style="max-width: 860px; margin: 0 auto;">

    <div class="reveal">
      <p class="section-eyebrow"><span>05</span> Education</p>
      <h2 id="education-heading" style="font-size: clamp(1.6rem, 3.5vw, 2.4rem); font-weight: 800; letter-spacing: -0.03em; margin: 0 0 2.75rem; line-height: 1.1;">
        Academic <span class="gradient-text">Background</span>
      </h2>
    </div>

    <div style="display: flex; flex-direction: column; gap: 0.85rem;">
      {education.map((edu, i) => (
        <div
          class="reveal glass glass-hover"
          style={`
            display: flex; align-items: center; gap: 1.25rem;
            padding: 1.35rem 1.6rem; border-radius: 16px;
            transition-delay: ${i * 0.1}s;
          `}
        >
          <!-- Icon -->
          <div style="
            width: 48px; height: 48px; border-radius: 12px; flex-shrink: 0;
            background: linear-gradient(135deg, rgba(129,140,248,0.15), rgba(103,232,249,0.1));
            border: 1px solid rgba(129,140,248,0.2);
            display: flex; align-items: center; justify-content: center;
            font-size: 1.35rem;
          " aria-hidden="true">🎓</div>

          <div style="flex: 1; min-width: 0;">
            <h3 style="font-size: 0.97rem; font-weight: 700; color: #fafafa; margin: 0 0 0.25rem; letter-spacing: -0.01em;">{edu.degree}</h3>
            <p style="font-size: 0.86rem; color: #818cf8; margin: 0 0 0.15rem; font-weight: 500;">{edu.institution}</p>
            <p style="font-size: 0.76rem; color: #3f3f46; margin: 0;">{edu.location}</p>
          </div>

          {edu.year && (
            <div style="font-size: 0.78rem; color: #52525b; flex-shrink: 0; font-weight: 500;">{edu.year}</div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  html.light #education h2 { color: #111111; }
  html.light #education h3 { color: #111111 !important; }
  html.light #education p[style*="color: #3f3f46"] { color: #6b7280 !important; }
  html.light #education div[style*="color: #52525b"] { color: #6b7280 !important; }
</style>
